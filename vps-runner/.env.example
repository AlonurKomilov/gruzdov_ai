# =====================================================
# P2C Catcher VPS Configuration
# =====================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =====================================================

# --- Telegram Bot for remote control ---
# Create a bot via @BotFather, paste token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (send /start to @userinfobot to get it)
# Only this user can control the catcher
TELEGRAM_ADMIN_ID=your_user_id_here

# --- P2C Target URL ---
P2C_URL=https://app.send.tg/p2c/orders

# --- P2C Page Filters ---
# Payment method name as shown on the page (e.g. Озон, СБП, Тинькофф)
PAYMENT_METHOD=Озон
# Sum range in RUB (the two fields on the P2C page)
SUM_MIN=10
SUM_MAX=400

# --- Catcher defaults ---
ORDER_LIMIT=1
MIN_DELAY=0
MAX_DELAY=0
SOUND_ENABLED=false
PAUSE_AFTER_CATCH=true

# --- Browser settings ---
# Path to Chrome/Chromium (leave empty for bundled)
CHROME_PATH=
# If true, shows browser window (needs X11/VNC)
HEADLESS=true
# User data dir for saving Telegram login session
USER_DATA_DIR=./chrome-data

# --- VNC (optional, for debugging) ---
# Install TigerVNC: apt install tigervnc-standalone-server
# Then run: vncserver :1 -geometry 1280x720
# Connect from your PC with a VNC client
VNC_DISPLAY=:1

# --- Screenshots ---
# Save periodic screenshots for remote monitoring
SCREENSHOT_INTERVAL=30
SCREENSHOT_DIR=./screenshots

# --- Web Dashboard ---
# Local port for the dashboard (exposed via Cloudflare Tunnel)
DASHBOARD_PORT=8385
# Auth token for dashboard access (auto-generated if empty)
# Set your own for a stable URL: any random string
DASHBOARD_TOKEN=
# Set to false to disable Cloudflare tunnel
CLOUDFLARE_TUNNEL=true
